{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AMI client",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Web server",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "Local: AMI + Web",
      "configurations": ["AMI client", "Web server"],
      "stopAll": true
    }
  ]
}
